{
  "name": "app-constants",
  "type": "module",
  "version": "0.0.0",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "tsc": "tsc --noEmit --watch",
    "prettier": "prettier . --write --config .prettierrc.json",
    "eslint": "eslint . --fix",
    "precommit": "lint-staged"
  },
  "devDependencies": {
    "@types/node": "22.10.10",
    "eslint": "9.34.0",
    "eslint-config": "*",
    "lint-staged": "16.1.2",
    "prettier": "3.6.2",
    "prettier-config": "*",
    "tsconfig": "*",
    "typescript": "5.8.3"
  },
  "lint-staged": {
    "*.ts": [
      "eslint . --fix",
      "bash -c 'tsc --noEmit'",
      "prettier . --write"
    ],
    "*.{json,md}": [
      "prettier . --write"
    ]
  }
}
