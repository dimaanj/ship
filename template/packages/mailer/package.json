{
  "name": "mailer",
  "type": "module",
  "version": "0.0.0",
  "description": "Ship Mailer based on React Email",
  "author": "Paralect",
  "license": "MIT",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "dev": "email dev --port 4000",
    "export": "email export",
    "tsc": "tsc --noEmit --watch",
    "prettier": "prettier . --write --config .prettierrc.json",
    "eslint": "eslint . --fix",
    "precommit": "lint-staged"
  },
  "dependencies": {
    "@react-email/components": "1.0.1",
    "@react-email/render": "2.0.0",
    "react": "19.0.3",
    "react-dom": "19.0.3"
  },
  "devDependencies": {
    "@react-email/preview-server": "5.0.8",
    "@types/node": "22.10.10",
    "@types/react": "19.0.14",
    "eslint": "9.34.0",
    "eslint-config": "*",
    "lint-staged": "16.1.2",
    "prettier": "3.6.2",
    "prettier-config": "*",
    "react-email": "5.0.8",
    "tsconfig": "*",
    "typescript": "5.8.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint . --fix",
      "bash -c 'tsc --noEmit'",
      "prettier . --write"
    ],
    "*.{json,md}": [
      "prettier . --write"
    ]
  }
}
