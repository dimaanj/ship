{
  "name": "shared",
  "type": "module",
  "version": "0.0.0",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "generate": "tsx scripts/generate.ts",
    "generate:watch": "tsx scripts/generate.ts --watch",
    "tsc": "tsc --noEmit --watch",
    "prettier": "prettier . --write --config .prettierrc.json",
    "eslint": "eslint . --fix",
    "precommit": "lint-staged"
  },
  "dependencies": {
    "axios": "1.8.1",
    "zod": "4.0.5"
  },
  "devDependencies": {
    "@types/node": "22.10.10",
    "chokidar": "^4.0.3",
    "eslint": "9.34.0",
    "eslint-config": "*",
    "lint-staged": "16.1.2",
    "prettier": "3.6.2",
    "prettier-config": "*",
    "tsconfig": "*",
    "tsx": "4.20.3",
    "typescript": "5.8.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint . --fix",
      "bash -c 'tsc --noEmit'",
      "prettier . --write"
    ],
    "*.{json,md}": [
      "prettier . --write"
    ]
  }
}
