{
  "name": "api",
  "type": "module",
  "version": "1.0.0",
  "description": "NestJS API",
  "author": "Paralect",
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "dev": "NODE_ENV=development APP_ENV=development nest start --watch",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "migrate-dev": "NODE_ENV=development APP_ENV=development tsx --env-file=.env src/migrator/run.ts",
    "migrate": "tsx src/migrator/run.ts",
    "schedule-dev": "NODE_ENV=development APP_ENV=development nest start --entryFile scheduler.main --watch",
    "schedule": "node dist/scheduler.main.js",
    "tsc": "tsc --noEmit --watch",
    "prettier": "prettier . --write --config .prettierrc.json",
    "eslint": "eslint . --fix",
    "precommit": "lint-staged"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.828.0",
    "@aws-sdk/lib-storage": "3.828.0",
    "@aws-sdk/s3-request-presigner": "3.828.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/event-emitter": "^3.0.0",
    "@nestjs/mongoose": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.0.0",
    "@nestjs/schedule": "^5.0.0",
    "@nestjs/throttler": "^6.0.0",
    "@nestjs/websockets": "^11.0.0",
    "@node-rs/argon2": "2.0.2",
    "@oslojs/crypto": "1.0.1",
    "@oslojs/encoding": "1.1.0",
    "@socket.io/redis-adapter": "8.3.0",
    "@socket.io/redis-emitter": "5.1.0",
    "app-constants": "*",
    "arctic": "3.7.0",
    "dayjs": "1.11.13",
    "helmet": "^8.0.0",
    "ioredis": "5.6.1",
    "lodash": "4.17.21",
    "mailer": "*",
    "mixpanel": "0.18.1",
    "mongoose": "^8.0.0",
    "resend": "4.5.2",
    "rxjs": "^7.8.0",
    "shared": "*",
    "socket.io": "4.8.1",
    "tldts": "7.0.8",
    "winston": "3.17.0",
    "zod": "4.0.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@types/lodash": "4.17.17",
    "@types/node": "22.10.10",
    "eslint": "9.34.0",
    "eslint-config": "*",
    "lint-staged": "16.1.2",
    "prettier": "3.6.2",
    "prettier-config": "*",
    "tsconfig": "*",
    "tsx": "4.20.4",
    "typescript": "5.8.3"
  },
  "lint-staged": {
    "*.ts": [
      "eslint . --fix",
      "bash -c 'tsc --noEmit'",
      "prettier . --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
